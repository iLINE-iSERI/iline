rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isImage() {
      return request.resource.contentType != null
        && request.resource.contentType.matches('image/.*');
    }

    function isUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    function isUnder20MB() {
      return request.resource.size < 20 * 1024 * 1024;
    }

    // ===== 오프라인 강좌 포스터 =====
    // 누구나 (로그인 사용자) 읽기, 관리자만 업로드/삭제, 5MB 이미지만
    match /posters/offline-courses/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isImage() && isUnder5MB();
      allow delete: if isAdmin();
    }

    // ===== 보상 상품 이미지 =====
    match /rewards/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isImage() && isUnder5MB();
      allow delete: if isAdmin();
    }

    // ===== 자료실 첨부 파일 (PDF, PPT, 한글 등 모든 형식 허용) =====
    match /posts/resource/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isUnder20MB();
      allow delete: if isAdmin();
    }

    // ===== 공지사항 첨부 이미지 =====
    match /posts/notice/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isImage() && isUnder5MB();
      allow delete: if isAdmin();
    }

    // 그 외 posts 경로 (호환성 — 기존 데이터)
    match /posts/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isImage() && isUnder5MB();
      allow delete: if isAdmin();
    }

    // 그 외 경로는 기본 거부
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
